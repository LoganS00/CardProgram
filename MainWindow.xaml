<Window x:Class="CardProgram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Card Collection"
        Width="1100" Height="720"
        MinWidth="600" MinHeight="400"
        Background="#13131f"
        WindowStyle="None"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="#3a3a5e" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#1a1a2e">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✦" Foreground="#8888ff" FontSize="16" Margin="0,0,8,0"/>
                        <TextBlock Text="Card Collection" Foreground="White"
                                   FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock x:Name="CountLabel" Foreground="#666688"
                                   FontSize="12" VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="—" Click="Minimize_Click"
                                Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="16" Cursor="Hand" Padding="10,0"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="MaximizeBtn" Content="□" Click="Maximize_Click"
                                Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="14" Cursor="Hand" Padding="10,0"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="✕" Click="Close_Click"
                                Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="14" Cursor="Hand" Padding="10,0"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════
                 HOME SCREEN
            ══════════════════════════════════════════ -->
            <Grid x:Name="HomeView" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="560">
                    <TextBlock Text="✦" Foreground="#8888ff" FontSize="48"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Card Collection" Foreground="White" FontSize="32"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="What would you like to do?" Foreground="#666688"
                               FontSize="15" HorizontalAlignment="Center" Margin="0,0,0,48"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Collection button -->
                        <Button Grid.Column="0" Click="GoCollection_Click" Cursor="Hand"
                                Background="#1a1a2e" BorderBrush="#3a3a6a" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16" Padding="32,36">
                                        <StackPanel>
                                            <TextBlock Text="🗂" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                            <TextBlock Text="Collection" Foreground="White" FontSize="22"
                                                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <TextBlock Text="Browse and manage&#10;your owned cards"
                                                       Foreground="#666688" FontSize="13"
                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#252545"/>
                                            <Setter Property="BorderBrush" Value="#6666aa"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Watch List button -->
                        <Button Grid.Column="2" Click="GoWatchlist_Click" Cursor="Hand"
                                Background="#1a1a2e" BorderBrush="#3a3a6a" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="16" Padding="32,36">
                                        <StackPanel>
                                            <TextBlock Text="👁" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                            <TextBlock Text="Watch List" Foreground="White" FontSize="22"
                                                       FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <TextBlock Text="Track cards you want&#10;and monitor prices"
                                                       Foreground="#666688" FontSize="13"
                                                       HorizontalAlignment="Center" TextAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1a2535"/>
                                            <Setter Property="BorderBrush" Value="#4488aa"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════════
                 WATCH LIST VIEW
            ══════════════════════════════════════════ -->
            <Grid x:Name="WatchlistView" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1a1a2e" Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="← Home" Click="WatchlistHome_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#334455" Margin="0,0,8,0"/>
                            <Button Content="🌐  Add to Watch List"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Click="WatchlistAdd_Click" Margin="0,0,8,0"/>
                            <Button Content="$ Refresh Prices"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#225533" Click="WatchlistRefresh_Click" Margin="0,0,8,0"/>
                        </StackPanel>
                        <TextBlock x:Name="WatchlistTotalLabel" Foreground="#55ee88"
                                   FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Background="#13131f">
                    <StackPanel>
                        <TextBlock x:Name="WatchlistEmptyLabel"
                                   Text="No cards on your watch list yet. Click Add to Watch List to start tracking."
                                   Foreground="#555577" FontSize="15"
                                   HorizontalAlignment="Center" Margin="0,80,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center"/>
                        <WrapPanel x:Name="WatchlistGrid" Margin="16,8" Orientation="Horizontal"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ══════════════════════════════════════════
                 COLLECTION VIEW
            ══════════════════════════════════════════ -->
            <Grid x:Name="CollectionView" Grid.Row="1" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" MinWidth="140" MaxWidth="260"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Folder sidebar -->
                <Border Grid.Column="0" Background="#12121e" BorderBrush="#2a2a44" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Sidebar header -->
                        <Border Grid.Row="0" Background="#1a1a2e" Padding="12,10">
                            <TextBlock Text="FOLDERS" Foreground="#666688" FontSize="10" FontWeight="SemiBold"/>
                        </Border>

                        <!-- Folder list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="FolderList" Margin="0,6,0,6"/>
                        </ScrollViewer>

                        <!-- New folder button -->
                        <Border Grid.Row="2" Background="#1a1a2e" Padding="10,8">
                            <Button Content="+ New Folder" Click="NewFolder_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#252540" FontSize="12"
                                    HorizontalAlignment="Stretch"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Resize grip -->
                <GridSplitter Grid.Column="1" Width="4" Background="#2a2a44"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

                <!-- Cards panel -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1a1a2e" Padding="16,10">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="← Home" Click="CollectionHome_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#334455" Margin="0,0,10,0"/>
                                <Button Content="🌐  Browse &amp; Add"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="BrowserAdd_Click" Margin="0,0,8,0"/>
                                <Button Content="$ Refresh Prices"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#225533"
                                        Click="RefreshPrices_Click" Margin="0,0,8,0"/>
                            </StackPanel>
                            <TextBox x:Name="SearchBox"
                                     HorizontalAlignment="Right" Width="200"
                                     Background="#2a2a3e" Foreground="White"
                                     CaretBrush="White" BorderBrush="#4a4a6a"
                                     BorderThickness="1" Padding="10,6"
                                     FontSize="13" VerticalAlignment="Center"
                                     TextChanged="Search_Changed">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <TextBlock Text="Search cards…" Foreground="#666688"
                                                                       Margin="10,6" FontSize="13"
                                                                       Visibility="{Binding Text.IsEmpty,
                                                                           RelativeSource={RelativeSource TemplatedParent},
                                                                           Converter={StaticResource BoolToVisConverter}}"/>
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>
                    </Border>

                    <!-- Card grid -->
                    <ScrollViewer x:Name="CardScrollView" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Background="#13131f">
                        <StackPanel>
                            <TextBlock x:Name="EmptyLabel"
                                       Text="No cards yet. Click Browse &amp; Add to get started."
                                       Foreground="#555577" FontSize="16"
                                       HorizontalAlignment="Center" Margin="0,80,0,0"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                            <WrapPanel x:Name="CardGrid" Margin="16,8" Orientation="Horizontal"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- ══════════════════════════════════════════
                 BROWSER VIEW  (top-level — shared by Collection & Watch List)
            ══════════════════════════════════════════ -->
            <Grid x:Name="BrowserView" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1a1a2e" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,8,0">
                            <Button x:Name="BrowserBackBtn" Content="← Collection" Click="BrowserBack_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#334455" Margin="0,0,6,0"/>
                            <Button Content="◀" Click="NavBack_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#2a2a3e" Padding="10,6" Margin="0,0,4,0"/>
                            <Button Content="▶" Click="NavForward_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#2a2a3e" Padding="10,6" Margin="0,0,4,0"/>
                            <Button Content="↺" Click="NavReload_Click"
                                    Style="{StaticResource ActionButtonStyle}"
                                    Background="#2a2a3e" Padding="10,6"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#2a2a3e" CornerRadius="6"
                                BorderBrush="#4a4a6a" BorderThickness="1" Margin="8,0">
                            <TextBox x:Name="AddressBar" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,6" FontSize="12"
                                     CaretBrush="White" VerticalContentAlignment="Center"
                                     KeyDown="AddressBar_KeyDown"/>
                        </Border>
                        <Button Grid.Column="2" Content="✦  Add This Card"
                                Style="{StaticResource ActionButtonStyle}"
                                FontSize="13" Padding="16,6" Click="AddThisCard_Click"/>
                    </Grid>
                </Border>

                <Border x:Name="AddCardForm" Grid.Row="1" Background="#252538"
                        Padding="14,10" Visibility="Collapsed"
                        BorderBrush="#5555cc" BorderThickness="0,0,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#2a2a3e" CornerRadius="6"
                                BorderBrush="#4a4a6a" BorderThickness="1" Margin="0,0,8,0">
                            <TextBox x:Name="FormName" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,7" FontSize="12"
                                     CaretBrush="White" ToolTip="Card Name"/>
                        </Border>
                        <Border Grid.Column="1" Background="#2a2a3e" CornerRadius="6"
                                BorderBrush="#4a4a6a" BorderThickness="1" Margin="0,0,8,0">
                            <TextBox x:Name="FormSet" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,7" FontSize="12"
                                     CaretBrush="White" ToolTip="Set Name"/>
                        </Border>
                        <Border Grid.Column="2" Background="#2a2a3e" CornerRadius="6"
                                BorderBrush="#4a4a6a" BorderThickness="1" Margin="0,0,8,0">
                            <TextBox x:Name="FormPrice" Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="10,7" FontSize="12"
                                     CaretBrush="White" ToolTip="Market Price ($)"/>
                        </Border>
                        <Button Grid.Column="3" Content="💾 Save" Style="{StaticResource ActionButtonStyle}"
                                Padding="14,7" Margin="0,0,6,0" Click="FormSave_Click"/>
                        <Button Grid.Column="4" Content="✕" Click="FormCancel_Click"
                                Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="14" Cursor="Hand" Padding="6,0"/>
                    </Grid>
                </Border>

                <wv2:WebView2 x:Name="Browser" Grid.Row="2"
                              NavigationCompleted="Browser_NavigationCompleted"
                              NavigationStarting="Browser_NavigationStarting"/>
            </Grid>

            <!-- ══════════════════════════════════════════
                 MASS ADD PROGRESS OVERLAY
            ══════════════════════════════════════════ -->
            <Grid x:Name="MassAddView" Grid.Row="1" Visibility="Collapsed" Background="#13131f">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="480">
                    <TextBlock Text="⊕ Mass Add" Foreground="White" FontSize="22"
                               FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <Border Background="#1e1e30" CornerRadius="10" Padding="28,22">
                        <StackPanel>
                            <TextBlock x:Name="MassAddProgressLabel"
                                       Foreground="#aaaacc" FontSize="14" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Margin="0,0,0,16"/>
                            <ProgressBar x:Name="MassAddProgressBar" Height="8" Margin="0,0,0,20"
                                         Minimum="0" Maximum="100" Value="0"
                                         Background="#2a2a3e" Foreground="#6666ff"
                                         BorderThickness="0"/>
                            <ScrollViewer MaxHeight="260" VerticalScrollBarVisibility="Auto"
                                          x:Name="MassAddResultScroll">
                                <StackPanel x:Name="MassAddResultStack"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    <Button x:Name="MassAddCancelBtn" Content="Cancel" Margin="0,16,0,0"
                            Style="{StaticResource ActionButtonStyle}" Background="#443333"
                            HorizontalAlignment="Center" Padding="24,8"
                            Click="MassAddCancel_Click"/>
                </StackPanel>
            </Grid>

            <!-- Status bar -->
            <Border Grid.Row="2" Background="#1a1a2e" Padding="16,8">
                <TextBlock x:Name="StatusLabel" Foreground="#555577" FontSize="11" Text="Ready"/>
            </Border>
        </Grid>
    </Border>
</Window>
