<Window x:Class="CardProgram.CardViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" Background="#1e1e2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="420" MinHeight="480"
        KeyDown="Window_KeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="#1e1e2e" BorderBrush="#3a3a5e" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>       <!-- scrollable content -->
                <RowDefinition Height="Auto"/>    <!-- buttons — always visible -->
            </Grid.RowDefinitions>

            <!-- Scrollable card content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#1e1e2e">
                <StackPanel Margin="20">

                    <!-- Header -->
                    <Grid Margin="0,0,0,14">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TitleBlock" Foreground="White"
                                       FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SetBlock" Foreground="#8888ff"
                                       FontSize="12" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Click="Close_Click" Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="16" Cursor="Hand"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </Grid>

                    <!-- Full card image -->
                    <Border BorderBrush="#4a4a6a" BorderThickness="1" CornerRadius="8"
                            Background="#111122" Margin="0,0,0,16">
                        <Image x:Name="CardImage" Stretch="Uniform"
                               MaxHeight="460" Margin="10"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               SnapsToDevicePixels="True"/>
                    </Border>

                    <!-- Price info row -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#111122" CornerRadius="8"
                                Padding="14,10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="MARKET" Foreground="#666688"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock x:Name="MarketBlock" Foreground="#55ee88"
                                           FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#111122" CornerRadius="8"
                                Padding="14,10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="LOW" Foreground="#666688"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LowBlock" Foreground="#aaaacc"
                                           FontSize="22" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#111122" CornerRadius="8"
                                Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="UPDATED" Foreground="#666688"
                                           FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock x:Name="UpdatedBlock" Foreground="#888899"
                                           FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Quantity -->
                    <Border Background="#111122" CornerRadius="8" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <TextBlock Text="QUANTITY" Foreground="#666688" FontSize="10"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="−" x:Name="QtyMinus" Click="QtyMinus_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2a2a3e" Padding="10,4" FontSize="14"/>
                                <TextBlock x:Name="QtyBlock" Foreground="White" FontSize="16"
                                           FontWeight="Bold" VerticalAlignment="Center"
                                           Margin="14,0" MinWidth="24" TextAlignment="Center"/>
                                <Button Content="+" x:Name="QtyPlus" Click="QtyPlus_Click"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#2a2a3e" Padding="10,4" FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Card type selector -->
                    <Border Background="#111122" CornerRadius="8" Padding="14,10" Margin="0,0,0,12">
                        <Grid>
                            <TextBlock Text="TYPE" Foreground="#666688" FontSize="10"
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <RadioButton x:Name="TypeFoil" Content="Foil" GroupName="CardType"
                                             Foreground="#aaaacc" FontSize="12" Margin="0,0,16,0"
                                             Checked="CardType_Changed"/>
                                <RadioButton x:Name="TypeNonFoil" Content="Non-Foil" GroupName="CardType"
                                             Foreground="#aaaacc" FontSize="12" Margin="0,0,16,0"
                                             Checked="CardType_Changed"/>
                                <RadioButton x:Name="TypeDamaged" Content="Damaged" GroupName="CardType"
                                             Foreground="#aaaacc" FontSize="12"
                                             Checked="CardType_Changed"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Price history graph -->
                    <Border x:Name="GraphBorder" Background="#111122" CornerRadius="8"
                            Padding="16" Margin="0,0,0,4" Visibility="Collapsed">
                        <StackPanel>
                            <!-- Stats row -->
                            <Grid Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Border Background="#1a1a2e" CornerRadius="6" Padding="10,5" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="CURRENT" Foreground="#555577" FontSize="9"/>
                                            <TextBlock x:Name="GraphCurrentBlock" Foreground="#55ee88" FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#1a1a2e" CornerRadius="6" Padding="10,5" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock Text="HIGH" Foreground="#555577" FontSize="9"/>
                                            <TextBlock x:Name="GraphHighBlock" Foreground="#eebb55" FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#1a1a2e" CornerRadius="6" Padding="10,5">
                                        <StackPanel>
                                            <TextBlock Text="LOW" Foreground="#555577" FontSize="9"/>
                                            <TextBlock x:Name="GraphLowBlock" Foreground="#aaaacc" FontSize="13" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Range selector -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="PRICE HISTORY" Foreground="#666688"
                                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <Button x:Name="RangeAll" Content="All" Tag="0"   Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#3a3a6a" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="Range1W"  Content="1W"  Tag="7"   Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#252535" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="Range1M"  Content="1M"  Tag="30"  Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#252535" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="Range3M"  Content="3M"  Tag="90"  Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#252535" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="Range6M"  Content="6M"  Tag="180" Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#252535" Padding="10,4" Margin="0,0,4,0" FontSize="11"/>
                                <Button x:Name="Range1Y"  Content="1Y"  Tag="365" Click="RangeBtn_Click"
                                        Style="{StaticResource ActionButtonStyle}" Background="#252535" Padding="10,4" FontSize="11"/>
                            </StackPanel>
                            <Canvas x:Name="GraphCanvas" Height="140" Background="Transparent"
                                    HorizontalAlignment="Stretch"
                                    SizeChanged="GraphCanvas_SizeChanged"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="NotesBlock" Foreground="#888899" FontSize="12"
                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                    <TextBlock x:Name="DateBlock" Foreground="#555577" FontSize="11"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Always-visible button bar -->
            <Border Grid.Row="1" Background="#161625" Padding="16,12"
                    BorderBrush="#3a3a5e" BorderThickness="0,1,0,0">
                <Grid>
                    <Button Content="🗑  Delete Card" HorizontalAlignment="Left"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#5a1a1a" Click="Delete_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="RefreshPriceBtn" Content="↻  Refresh Price"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#1a3a2a" Margin="0,0,8,0" Click="RefreshPrice_Click"/>
                        <Button Content="Close"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#333344" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
