<Window x:Class="CardProgram.BrowserAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Add Card from TCGPlayer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Width="1100" Height="780">

    <Border Background="#1e1e2e" CornerRadius="12"
            BorderBrush="#5555cc" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Background="#1a1a2e" CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🌐" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Browse TCGPlayer — navigate to a card, then click Add This Card"
                                   Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="✕" Click="Close_Click"
                                Background="Transparent" Foreground="#aaaacc"
                                BorderThickness="0" FontSize="14" Cursor="Hand" Padding="8,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Address bar -->
            <Border Grid.Row="1" Background="#13131f" Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,8,0">
                        <Button Content="◀" Click="Back_Click" Style="{StaticResource ActionButtonStyle}"
                                Background="#2a2a3e" Padding="8,4" FontSize="12" Margin="0,0,4,0"/>
                        <Button Content="▶" Click="Forward_Click" Style="{StaticResource ActionButtonStyle}"
                                Background="#2a2a3e" Padding="8,4" FontSize="12" Margin="0,0,4,0"/>
                        <Button Content="↺" Click="Reload_Click" Style="{StaticResource ActionButtonStyle}"
                                Background="#2a2a3e" Padding="8,4" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#2a2a3e" CornerRadius="6"
                            BorderBrush="#4a4a6a" BorderThickness="1" Margin="0,0,8,0">
                        <TextBox x:Name="AddressBar" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="10,5" FontSize="12" CaretBrush="White"
                                 VerticalContentAlignment="Center"
                                 KeyDown="AddressBar_KeyDown"/>
                    </Border>

                    <Button Grid.Column="2" Content="✦  Add This Card"
                            Style="{StaticResource ActionButtonStyle}"
                            FontSize="13" Padding="16,6"
                            Click="AddThisCard_Click"/>
                </Grid>
            </Border>

            <!-- WebView2 browser -->
            <wv2:WebView2 x:Name="Browser" Grid.Row="2"
                          NavigationCompleted="Browser_NavigationCompleted"
                          NavigationStarting="Browser_NavigationStarting"/>

            <!-- Status bar -->
            <Border Grid.Row="3" Background="#1a1a2e" Padding="14,8" CornerRadius="0,0,10,10">
                <TextBlock x:Name="StatusLabel" Foreground="#555577" FontSize="11" Text="Loading…"/>
            </Border>
        </Grid>
    </Border>
</Window>
