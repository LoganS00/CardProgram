<Window x:Class="CardProgram.CardConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Card"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight"
        MinWidth="720">

    <Border Background="#1e1e2e" CornerRadius="12" Padding="24"
            BorderBrush="#5555cc" BorderThickness="2">
        <StackPanel>
            <TextBlock Text="Confirm Your Card" Foreground="White"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock x:Name="SubLabel" Foreground="#888899" FontSize="12" Margin="0,0,0,20"
                       TextWrapping="Wrap"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Captured image -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="YOUR CAPTURE" Foreground="#8888ff" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,8" TextAlignment="Center"/>
                    <Border BorderBrush="#4a4a6a" BorderThickness="1" CornerRadius="6"
                            Background="#111122" MinHeight="200">
                        <Image x:Name="CaptureImage" MaxHeight="300" MaxWidth="300"
                               Stretch="Uniform" Margin="8"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="↔" Foreground="#555577"
                           FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                <!-- TCGPlayer match -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="TCGPLAYER MATCH" Foreground="#55ee88" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,8" TextAlignment="Center"/>
                    <Border BorderBrush="#4a4a6a" BorderThickness="1" CornerRadius="6"
                            Background="#111122" MinHeight="200">
                        <StackPanel x:Name="MatchPanel" Margin="12" VerticalAlignment="Center">

                            <!-- State: loading -->
                            <TextBlock x:Name="LoadingLabel" Text="Searching TCGPlayer…"
                                       Foreground="#888899" FontSize="13"
                                       TextAlignment="Center" Visibility="Collapsed"/>

                            <!-- State: no match -->
                            <StackPanel x:Name="NoMatchPanel" Visibility="Collapsed">
                                <TextBlock Text="No match found." Foreground="#888899"
                                           FontSize="13" TextAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="Try a different search:" Foreground="#aaaacc"
                                           FontSize="11" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="#2a2a3e" CornerRadius="6"
                                            BorderBrush="#4a4a6a" BorderThickness="1">
                                        <TextBox x:Name="InlineSearchBox" Background="Transparent"
                                                 Foreground="White" BorderThickness="0"
                                                 Padding="8,6" FontSize="12" CaretBrush="White"
                                                 KeyDown="InlineSearch_KeyDown"/>
                                    </Border>
                                    <Button Grid.Column="1" Content="Go" Margin="6,0,0,0"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Padding="10,6" Click="InlineSearch_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- State: match found -->
                            <StackPanel x:Name="MatchFoundPanel" Visibility="Collapsed">
                                <Image x:Name="TcgImage" MaxHeight="180" MaxWidth="220"
                                       Stretch="Uniform" Margin="0,0,0,10"
                                       HorizontalAlignment="Center"/>
                                <TextBlock x:Name="MatchName" Foreground="White"
                                           FontSize="14" FontWeight="Bold"
                                           TextWrapping="Wrap" TextAlignment="Center"/>
                                <TextBlock x:Name="MatchSet" Foreground="#aaaacc"
                                           FontSize="11" TextAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock x:Name="MatchPrice" Foreground="#55ee88"
                                           FontSize="16" FontWeight="Bold"
                                           TextAlignment="Center" Margin="0,10,0,0"/>
                                <Button Content="Wrong card? Search again"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Background="#334455" Margin="0,10,0,0"
                                        FontSize="11" Padding="8,4"
                                        Click="SearchAgain_Click"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Card name + notes -->
            <TextBlock Text="Card Name:" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a"
                    BorderThickness="1" Margin="0,0,0,10">
                <TextBox x:Name="CardNameBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"/>
            </Border>

            <TextBlock Text="Notes (optional):" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a"
                    BorderThickness="1" Margin="0,0,0,20">
                <TextBox x:Name="NotesBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"
                         TextWrapping="Wrap" Height="50" AcceptsReturn="True"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Skip Pricing" Click="SkipPricing_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#444455" Margin="0,0,10,0"/>
                <Button Content="✓  Save Card" Click="Confirm_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
