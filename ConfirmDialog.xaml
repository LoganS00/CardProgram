<Window x:Class="CardProgram.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" SizeToContent="WidthAndHeight"
        ResizeMode="NoResize">
    <Border Background="#1e1e2e" CornerRadius="10" Padding="28,24"
            BorderBrush="#882222" BorderThickness="2" Width="360">
        <StackPanel>
            <TextBlock x:Name="TitleBlock" Foreground="White" FontSize="16"
                       FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap"/>
            <TextBlock x:Name="MessageBlock" Foreground="#aaaacc" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,24"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="NoBtn" Content="Cancel" Click="No_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#333344" Margin="0,0,10,0"/>
                <Button x:Name="YesBtn" Content="Delete" Click="Yes_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#882222"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
