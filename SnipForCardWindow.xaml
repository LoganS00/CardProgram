<Window x:Class="CardProgram.SnipForCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Save Card"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">

    <Border Background="#1e1e2e" CornerRadius="12" Padding="24"
            BorderBrush="#5555cc" BorderThickness="2" Width="420">
        <StackPanel>
            <TextBlock Text="Save Card to Collection" Foreground="White"
                       FontSize="17" FontWeight="Bold" Margin="0,0,0,16"/>

            <!-- TCGPlayer card image preview -->
            <Border Background="#111122" CornerRadius="6" Margin="0,0,0,14"
                    Visibility="{Binding HasTcgImage, RelativeSource={RelativeSource AncestorType=Window},
                                Converter={StaticResource BoolToVisConverter}}">
                <Image x:Name="TcgPreview" MaxHeight="180" Stretch="Uniform" Margin="8"/>
            </Border>

            <TextBlock Text="Card Name:" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a"
                    BorderThickness="1" Margin="0,0,0,12">
                <TextBox x:Name="NameBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"/>
            </Border>

            <TextBlock Text="Set:" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a"
                    BorderThickness="1" Margin="0,0,0,12">
                <TextBox x:Name="SetBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"/>
            </Border>

            <TextBlock Text="Market Price:" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,4"/>
            <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a"
                    BorderThickness="1" Margin="0,0,0,12">
                <TextBox x:Name="PriceBox" Background="Transparent" Foreground="White"
                         BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"/>
            </Border>

            <TextBlock Text="Card Image:" Foreground="#aaaacc" FontSize="12" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="📷  Snip Screenshot" Click="Snip_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#334455" Margin="0,0,8,0"/>
                <Button Content="📁  Choose File" Click="File_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#334455"/>
            </StackPanel>

            <Border x:Name="SnipPreviewBorder" Background="#111122" CornerRadius="6"
                    Margin="0,8,0,0" Visibility="Collapsed">
                <Image x:Name="SnipPreview" MaxHeight="160" Stretch="Uniform" Margin="8"/>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#444455" Margin="0,0,10,0"/>
                <Button Content="Save to Collection" Click="Save_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
