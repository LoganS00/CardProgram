<Window x:Class="CardProgram.MassAddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        WindowStyle="None" Background="#1e1e2e"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinWidth="560" MinHeight="500"
        Width="660" Height="620"
        KeyDown="Window_KeyDown">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border Background="#1e1e2e" BorderBrush="#3a3a5e" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#1a1a2e" Padding="20,14">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Mass Add Cards" Foreground="White" FontSize="17" FontWeight="Bold"/>
                        <TextBlock Foreground="#666688" FontSize="11" Margin="0,3,0,0">
                            <Run>One card per line — format: </Run>
                            <Run Foreground="#aaaaff">1 Kid &amp; Killer [EB-01]</Run>
                        </TextBlock>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Click="Close_Click" Background="Transparent" Foreground="#aaaacc"
                            BorderThickness="0" FontSize="16" Cursor="Hand"
                            WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </Border>

            <!-- Input -->
            <Border Grid.Row="1" Background="#111122" Padding="16,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#2a2a3e" CornerRadius="6"
                            BorderBrush="#4a4a6a" BorderThickness="1">
                        <TextBox x:Name="InputBox" Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="13"
                                 CaretBrush="White" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" TextWrapping="Wrap"/>
                    </Border>
                    <Button Grid.Row="1" Content="🔍  Find Cards" Margin="0,10,0,0"
                            x:Name="SearchBtn" Click="Search_Click"
                            Style="{StaticResource ActionButtonStyle}"
                            Background="#3a3a8a" Padding="16,8" FontSize="13"
                            HorizontalAlignment="Left"/>
                </Grid>
            </Border>

            <!-- Results -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="#13131f">
                <StackPanel>
                    <TextBlock x:Name="StatusBlock" Foreground="#666688" FontSize="12"
                               Margin="16,12,16,4" TextWrapping="Wrap"/>
                    <ItemsControl x:Name="ResultsList" Margin="12,0,12,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" Background="#161625" Padding="16,12"
                    BorderBrush="#3a3a5e" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock x:Name="SummaryBlock" Foreground="#666688" FontSize="12"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Click="Close_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#333344" Margin="0,0,8,0"/>
                        <Button x:Name="AddBtn" Content="Add All Found" IsEnabled="False"
                                Click="Add_Click"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#225533" Padding="16,7"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- Hidden browser for real-session TCGPlayer searches -->
            <wv2:WebView2 x:Name="HiddenBrowser" Grid.Row="0" Grid.RowSpan="4"
                          Visibility="Collapsed" Width="0" Height="0"
                          HorizontalAlignment="Left" VerticalAlignment="Top"/>
        </Grid>
    </Border>
</Window>
