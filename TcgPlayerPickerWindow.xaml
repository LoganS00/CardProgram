<Window x:Class="CardProgram.TcgPlayerPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Link to TCGPlayer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Width="480" Height="520">

    <Border Background="#1e1e2e" CornerRadius="12" Padding="20"
            BorderBrush="#5555cc" BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Link to TCGPlayer Card" Foreground="White"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,14"/>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="#2a2a3e" CornerRadius="6" BorderBrush="#4a4a6a" BorderThickness="1">
                    <TextBox x:Name="SearchBox" Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="10,8" FontSize="13" CaretBrush="White"
                             KeyDown="SearchBox_KeyDown"/>
                </Border>
                <Button Grid.Column="1" Content="Search" Margin="8,0,0,0"
                        Style="{StaticResource ActionButtonStyle}" Click="Search_Click"/>
            </Grid>

            <Border Grid.Row="2" Background="#111122" CornerRadius="6"
                    BorderBrush="#3a3a5e" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ResultsPanel" Margin="6"/>
                </ScrollViewer>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <TextBlock x:Name="StatusLabel" Foreground="#666688" FontSize="11"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Skip Pricing" Click="Skip_Click"
                        Style="{StaticResource ActionButtonStyle}"
                        Background="#444455" Margin="0,0,10,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
